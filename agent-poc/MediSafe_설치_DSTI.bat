        echo  수동 설치: https://www.python.org/downloads/
        echo  [Add Python to PATH] 체크 후 재설치하세요.
        pause
        exit /b 1
    )
    start "" "%~f0"
    exit /b 0
)
for /f "tokens=2" %%v in ('python --version 2^>^&1') do echo  [OK] Python %%v

REM ── 2. 라이브러리 설치
echo  [2/4] 라이브러리 설치 중...
